# Darwinian 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# LLM API Key (选择其一)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Semantic Scholar API Key (可选，无则使用公开接口，有速率限制)
# SEMANTIC_SCHOLAR_API_KEY=your_key_here

# 代码执行沙箱配置
# SANDBOX_IMAGE=darwinian-sandbox:latest  # 自定义 Docker 镜像
# SANDBOX_TIMEOUT=300                      # 执行超时（秒）
# SANDBOX_MEM_LIMIT=512m                   # 内存限制
